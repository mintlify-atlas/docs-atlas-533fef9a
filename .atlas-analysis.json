  "keyFeatures": [
    "AI-powered OCR extraction of flashcards from images, PDFs, and video files using Google Gemini",
    "Multi-key Gemini API rotation with parallel processing and automatic rate-limit handling",
    "Smart Merge cloud sync via Google Drive AppData (newer updated_at wins)",
    "Study mode with keyboard shortcuts, self-scoring, and undo functionality",
    "Quiz mode with single/multiple-choice questions, session save and resume",
    "Quizlet export in four formats: simple, full, compact, and safe",
    "Duplicate question detection using n-gram shingling and Jaccard similarity",
    "Cross-platform: Windows desktop (.NET 8 WPF), Python desktop (CustomTkinter), Android mobile (React Native)"
  ],
  "publicApiSurface": [
    "GeminiService.process_image(image_path, max_retries) -> Optional[Flashcard]",
    "GeminiService.process_images_as_pdf_batches(image_paths, batch_size, ...) -> List[Flashcard]",
    "GeminiService.process_images_parallel(image_paths, keys, ...) -> List[Flashcard]",
    "GeminiService.validate_keys_parallel(keys, on_log) -> List[str]",
    "SyncService.perform_full_sync() -> Tuple[bool, str]",
    "SyncService.sync_decks() -> Tuple[bool, str]",
    "export_to_quizlet(deck, output_path, format_type) -> str",
    "find_duplicate_questions(cards, threshold) -> List[Tuple[int, int, float]]",
    "Flashcard.to_dict() / Flashcard.from_dict(data)",
    "Deck.to_dict() / Deck.from_dict(data)",
    "QuizSession.new_for_deck(deck) -> QuizSession",
